# 12. First Kernel - Vector Add 2D - Tests
#
# SSpec tests for the vector_add kernel.
# Verifies correctness of 2D-indexed element-wise addition.

use std.gpu.*
use std.gpu_runtime.*

# ============================================================================
# Helpers (CPU reference implementation)
# ============================================================================

fn cpu_vector_add(a: [f32], b: [f32]) -> [f32]:
    var c: [f32] = []
    val n = a.len()
    for i in 0..n:
        c = c + [a[i] + b[i]]
    c

fn arrays_close(actual: [f32], expected: [f32], tol: f32) -> bool:
    if actual.len() != expected.len():
        return false
    for i in 0..actual.len():
        val diff = actual[i] - expected[i]
        val abs_diff = if diff < 0.0: 0.0 - diff else: diff
        if abs_diff > tol:
            return false
    true

# ============================================================================
# Tests
# ============================================================================

describe "Vector Add 2D":

    describe "CPU reference":

        it "adds two equal-length arrays element-wise":
            val a = [1.0, 2.0, 3.0, 4.0]
            val b = [10.0, 20.0, 30.0, 40.0]
            val c = cpu_vector_add(a, b)
            expect(c.len()).to_equal(4)
            expect(arrays_close(c, [11.0, 22.0, 33.0, 44.0], 0.001)).to_equal(true)

        it "handles empty arrays":
            val a: [f32] = []
            val b: [f32] = []
            val c = cpu_vector_add(a, b)
            expect(c.len()).to_equal(0)

        it "handles single-element arrays":
            val c = cpu_vector_add([5.0], [3.0])
            expect(arrays_close(c, [8.0], 0.001)).to_equal(true)

    describe "launch configuration":

        it "computes grid dimensions for small vectors":
            val width = 64
            val height = 32
            val block_x = 16
            val block_y = 16
            val grid_x = (width + block_x - 1) / block_x
            val grid_y = (height + block_y - 1) / block_y
            expect(grid_x).to_equal(4)
            expect(grid_y).to_equal(2)

        it "computes grid dimensions that cover non-aligned sizes":
            # 100 wide, 50 tall with 16x16 blocks
            val grid_x = (100 + 15) / 16
            val grid_y = (50 + 15) / 16
            expect(grid_x).to_equal(7)
            expect(grid_y).to_equal(4)
            # Total threads >= 100 * 50
            val total = grid_x * 16 * grid_y * 16
            expect(total >= 5000).to_equal(true)

        it "produces at least one block per dimension":
            val grid_x = (1 + 15) / 16
            val grid_y = (1 + 15) / 16
            expect(grid_x).to_equal(1)
            expect(grid_y).to_equal(1)

    describe "GPU kernel (requires hardware)":

        it "vector_add symbol exists":
            # Kernel decorator produces a callable symbol.
            # This test verifies the file loads without parse errors.
            val loaded = true
            expect(loaded).to_equal(true)
