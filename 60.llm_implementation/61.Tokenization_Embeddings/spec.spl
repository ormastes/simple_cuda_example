use std.gpu.{GpuDevice}

describe "Tokenization and embeddings":
    it "should create embedding table":
        val emb = TokenEmbedding.create(1000, 64)?
        expect(emb.vocab_size).to_equal(1000)
        expect(emb.embed_dim).to_equal(64)

    it "should lookup single token embedding":
        val emb = TokenEmbedding.create(100, 8)?
        val result = emb.lookup([0])?
        expect(result.shape[0]).to_equal(1)
        expect(result.shape[1]).to_equal(8)
        expect(result.data.len()).to_equal(8)

    it "should lookup batch of tokens":
        val emb = TokenEmbedding.create(100, 8)?
        val result = emb.lookup([1, 5, 10, 20])?
        expect(result.shape[0]).to_equal(4)
        expect(result.shape[1]).to_equal(8)
        expect(result.data.len()).to_equal(32)

    it "should produce different embeddings for different tokens":
        val emb = TokenEmbedding.create(100, 8)?
        val r1 = emb.lookup([0])?
        val r2 = emb.lookup([1])?
        # Different tokens should have different embeddings
        var differs = false
        var i = 0
        while i < 8:
            if r1.data[i] != r2.data[i]:
                differs = true
            i = i + 1
        expect(differs).to_equal(true)

    it "should compute positional encoding":
        val pe = compute_positional_encoding(4, 8)
        expect(pe.len()).to_equal(32)
        # Position 0, dim 0: sin(0) = 0.0
        expect(pe[0]).to_equal(0.0)
        # Position 0, dim 1: cos(0) = 1.0
        expect(pe[1]).to_equal(1.0)

    it "should add positional encoding to embeddings":
        val result = embed_tokens([0, 1], 100, 8, 64)?
        expect(result.shape[0]).to_equal(2)
        expect(result.shape[1]).to_equal(8)

    it "should build pipeline with ~> operator":
        val pipeline = build_embedding_pipeline(50000, 512, 2048)
        val desc = pipeline.describe()
        expect(desc).to_contain("Embedding")
        expect(desc).to_contain("PositionalEncoding")
