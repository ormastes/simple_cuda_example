use std.gpu.{GpuDevice, GpuBuffer}
use std.ml.{Tensor, Layer, Linear, LayerNorm, Embedding, PositionalEncoding,
            MultiHeadAttention, GELU, Residual, Softmax}
use std.io.{print}
use std.math.{exp, log}

# GPT configuration
class GptConfig:
    vocab_size: i64
    max_seq_len: i64
    d_model: i64
    num_heads: i64
    num_layers: i64
    d_ff: i64
    dropout: f32

    static fn gpt2_small() -> GptConfig:
        GptConfig(
            vocab_size: 50_257,
            max_seq_len: 1024,
            d_model: 768,
            num_heads: 12,
            num_layers: 12,
            d_ff: 3072,
            dropout: 0.1
        )

    static fn gpt2_medium() -> GptConfig:
        GptConfig(
            vocab_size: 50_257,
            max_seq_len: 1024,
            d_model: 1024,
            num_heads: 16,
            num_layers: 24,
            d_ff: 4096,
            dropout: 0.1
        )

    static fn small_test() -> GptConfig:
        GptConfig(
            vocab_size: 1000,
            max_seq_len: 128,
            d_model: 64,
            num_heads: 4,
            num_layers: 2,
            d_ff: 256,
            dropout: 0.0
        )

# GPT model
class GptModel:
    config: GptConfig
    token_embedding: Tensor<f32>      # [vocab_size, d_model]
    position_embedding: Tensor<f32>   # [max_seq_len, d_model]
    blocks: [TransformerBlock]
    ln_final: LNorm
    lm_head: Tensor<f32>             # [d_model, vocab_size] (output projection)

    static fn create(config: GptConfig) -> GptModel:
        # Initialize embeddings
        val token_emb = Tensor.randn([config.vocab_size, config.d_model])
        val pos_emb = Tensor.randn([config.max_seq_len, config.d_model])

        # Create transformer blocks
        var blocks: [TransformerBlock] = []
        var i = 0
        while i < config.num_layers:
            val block = TransformerBlock.create(config.d_model, config.num_heads, config.d_ff)
            blocks = blocks + [block]
            i = i + 1

        val ln_final = LNorm.create(config.d_model)
        val lm_head = Tensor.randn([config.d_model, config.vocab_size])

        GptModel(
            config: config,
            token_embedding: token_emb,
            position_embedding: pos_emb,
            blocks: blocks,
            ln_final: ln_final,
            lm_head: lm_head
        )

    # Forward pass: token_ids -> logits
    fn forward(self, token_ids: [i32]) -> Result<Tensor<f32>, GpuError>:
        val seq_len = token_ids.len()

        # Token embedding lookup
        var x = self.embed_tokens(token_ids)?

        # Add positional embeddings
        val pos_slice = self.position_embedding.slice_rows(0, seq_len)
        x = x.add(pos_slice)?

        # Pass through transformer blocks
        var i = 0
        while i < self.blocks.len():
            x = self.blocks[i].forward(x, causal: true)?
            i = i + 1

        # Final layer norm
        x = self.ln_final.forward(x)?

        # Project to vocabulary: [seq_len, d_model] @ [d_model, vocab_size] -> [seq_len, vocab_size]
        x.matmul(self.lm_head)

    fn embed_tokens(self, token_ids: [i32]) -> Result<Tensor<f32>, GpuError>:
        val seq_len = token_ids.len()
        val d = self.config.d_model
        var data = [f32].fill(seq_len * d, 0.0)
        var i = 0
        while i < seq_len:
            val tid = token_ids[i]
            var j = 0
            while j < d:
                data[i * d + j] = self.token_embedding.data[tid * d + j]
                j = j + 1
            i = i + 1
        Ok(Tensor(shape: [seq_len, d], data: data))

    # Get next token logits (last position only)
    fn next_token_logits(self, token_ids: [i32]) -> Result<[f32], GpuError>:
        val logits = self.forward(token_ids)?
        val seq_len = token_ids.len()
        val vocab_size = self.config.vocab_size
        # Extract last row
        val start = (seq_len - 1) * vocab_size
        Ok(logits.data[start..(start + vocab_size)])

# Top-k sampling from logits
fn top_k_sample(logits: [f32], k: i64, temperature: f32) -> i32:
    val n = logits.len()

    # Apply temperature
    var scaled: [f32] = []
    var i = 0
    while i < n:
        scaled = scaled + [logits[i] / temperature]
        i = i + 1

    # Find top-k indices (simplified: partial sort)
    var top_indices: [i64] = []
    var top_values: [f32] = []
    var j = 0
    while j < k:
        var best_idx = 0
        var best_val = -1.0e9f32
        i = 0
        while i < n:
            var already_selected = false
            var m = 0
            while m < top_indices.len():
                if top_indices[m] == i:
                    already_selected = true
                m = m + 1
            if not already_selected and scaled[i] > best_val:
                best_val = scaled[i]
                best_idx = i
            i = i + 1
        top_indices = top_indices + [best_idx]
        top_values = top_values + [best_val]
        j = j + 1

    # Softmax over top-k
    var max_val = top_values[0]
    i = 1
    while i < k:
        if top_values[i] > max_val:
            max_val = top_values[i]
        i = i + 1

    var exp_sum = 0.0f32
    var probs: [f32] = []
    i = 0
    while i < k:
        val e = exp(top_values[i] - max_val)
        probs = probs + [e]
        exp_sum = exp_sum + e
        i = i + 1

    i = 0
    while i < k:
        probs[i] = probs[i] / exp_sum
        i = i + 1

    # Sample (simplified: pick highest probability)
    var best_prob_idx = 0
    i = 1
    while i < k:
        if probs[i] > probs[best_prob_idx]:
            best_prob_idx = i
        i = i + 1

    top_indices[best_prob_idx].to_i32()

# Generate tokens autoregressively
fn generate(model: GptModel, prompt: [i32], max_new_tokens: i64,
            temperature: f32, top_k: i64) -> Result<[i32], GpuError>:
    var tokens = prompt
    var i = 0
    while i < max_new_tokens:
        val logits = model.next_token_logits(tokens)?
        val next_token = top_k_sample(logits, top_k, temperature)
        tokens = tokens + [next_token]
        i = i + 1
    Ok(tokens)

# Build GPT as pipeline using ~> operator
fn build_gpt_pipeline(config: GptConfig) -> Layer:
    var pipeline = Embedding(config.vocab_size, config.d_model)
        ~> PositionalEncoding(config.max_seq_len, config.d_model)

    var i = 0
    while i < config.num_layers:
        pipeline = pipeline ~> Residual(
            LayerNorm(config.d_model) ~> MultiHeadAttention(config.d_model, config.num_heads)
        ) ~> Residual(
            LayerNorm(config.d_model) ~> Linear(config.d_model, config.d_ff)
                ~> GELU() ~> Linear(config.d_ff, config.d_model)
        )
        i = i + 1

    pipeline ~> LayerNorm(config.d_model) ~> Linear(config.d_model, config.vocab_size)

fn main():
    val config = GptConfig.small_test()
    print "GPT model: {config.num_layers} layers, d_model={config.d_model}, heads={config.num_heads}"
    print "  vocab_size={config.vocab_size}, max_seq_len={config.max_seq_len}"

    val model = GptModel.create(config)

    # Example forward pass
    val prompt = [1, 42, 100, 7]
    print "Prompt tokens: {prompt}"

    val logits = model.forward(prompt)
    match logits:
        Ok(l):
            print "Logits shape: [{l.shape[0]}, {l.shape[1]}]"
        Err(e):
            print "Error: {e.message}"

    # Generate
    val generated = generate(model, prompt, max_new_tokens: 8,
                             temperature: 0.8, top_k: 50)
    match generated:
        Ok(tokens):
            print "Generated {tokens.len()} tokens: {tokens}"
        Err(e):
            print "Generation error: {e.message}"

    # Pipeline description
    val pipeline = build_gpt_pipeline(config)
    print "Pipeline layers: {pipeline.num_layers()}"
