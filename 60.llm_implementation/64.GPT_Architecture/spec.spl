use std.gpu.{GpuDevice}
use std.ml.{Tensor}

describe "GPT architecture":
    it "should create GPT config":
        val config = GptConfig.small_test()
        expect(config.d_model).to_equal(64)
        expect(config.num_layers).to_equal(2)
        expect(config.num_heads).to_equal(4)

    it "should create GPT model":
        val config = GptConfig.small_test()
        val model = GptModel.create(config)
        expect(model.blocks.len()).to_equal(2)

    it "should produce correct output shape":
        val config = GptConfig.small_test()
        val model = GptModel.create(config)
        val token_ids = [1, 5, 10]
        val logits = model.forward(token_ids)?
        # Output: [seq_len, vocab_size]
        expect(logits.shape[0]).to_equal(3)
        expect(logits.shape[1]).to_equal(config.vocab_size)

    it "should get next token logits":
        val config = GptConfig.small_test()
        val model = GptModel.create(config)
        val logits = model.next_token_logits([1, 5, 10])?
        expect(logits.len()).to_equal(config.vocab_size)

    it "should sample from top-k":
        val logits = [1.0, 5.0, 2.0, 0.5, 3.0]
        val token = top_k_sample(logits, 3, 1.0)
        # Should pick from top 3: indices 1(5.0), 4(3.0), 2(2.0)
        # With greedy (highest prob), should pick index 1
        expect(token).to_equal(1)

    it "should generate tokens autoregressively":
        val config = GptConfig.small_test()
        val model = GptModel.create(config)
        val prompt = [1, 2, 3]
        val result = generate(model, prompt, max_new_tokens: 4,
                              temperature: 1.0, top_k: 10)?
        expect(result.len()).to_equal(7)  # 3 prompt + 4 generated
        # First 3 should be the prompt
        expect(result[0]).to_equal(1)
        expect(result[1]).to_equal(2)
        expect(result[2]).to_equal(3)

    it "should build GPT pipeline":
        val config = GptConfig.small_test()
        val pipeline = build_gpt_pipeline(config)
        expect(pipeline.num_layers()).to_be_greater_than(0)

    it "should support GPT-2 small config":
        val config = GptConfig.gpt2_small()
        expect(config.d_model).to_equal(768)
        expect(config.num_layers).to_equal(12)
        expect(config.num_heads).to_equal(12)
        expect(config.vocab_size).to_equal(50257)
